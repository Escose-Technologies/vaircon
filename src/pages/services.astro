---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = "AC Repair & Installation Services Jaipur | Vishwakarma Aircon";
const description = "Complete AC services in Jaipur: repair, installation, shifting, commercial solutions, AMC & buy/sell old AC. 20+ years experience. Call 9928731910.";

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Service",
  "serviceType": "Air Conditioning Services",
  "provider": {
    "@type": "LocalBusiness",
    "name": "Vishwakarma Aircon",
    "telephone": "+919928731910",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Jaipur",
      "addressRegion": "Rajasthan",
      "addressCountry": "IN"
    }
  },
  "areaServed": {
    "@type": "City",
    "name": "Jaipur"
  },
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "AC Services",
    "itemListElement": [
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "AC Repair & Maintenance" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "New AC Installation" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "AC Shifting / Relocation" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Commercial AC Solutions" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Annual Maintenance Contract (AMC)" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Buy & Sell Old AC" } }
    ]
  }
};
---

<BaseLayout title={title} description={description} jsonLd={jsonLd}>

  <!-- Hero Section -->
  <section class="relative bg-gradient-to-r from-sky-500 to-cyan-400 pt-28 pb-20 overflow-hidden">
    <div class="absolute inset-0 opacity-10">
      <svg class="w-full h-full" xmlns="http://www.w3.org/2000/svg">
        <defs>
          <pattern id="hero-pattern" x="0" y="0" width="40" height="40" patternUnits="userSpaceOnUse">
            <circle cx="20" cy="20" r="1.5" fill="white" />
          </pattern>
        </defs>
        <rect width="100%" height="100%" fill="url(#hero-pattern)" />
      </svg>
    </div>
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 relative z-10 text-center">
      <h1 class="font-heading text-4xl md:text-5xl lg:text-6xl font-bold text-white mb-6 leading-tight">
        Professional AC Services in Jaipur
      </h1>
      <p class="text-white/90 text-lg md:text-xl max-w-3xl mx-auto mb-8 font-body leading-relaxed">
        From repair and installation to commercial solutions and AMC plans — Vishwakarma Aircon delivers reliable, expert air conditioning services across Jaipur with over 20 years of trusted experience.
      </p>
      <div class="flex flex-wrap justify-center gap-3 mb-8">
        <a href="#repair" class="bg-white text-sky-600 font-semibold px-4 py-2 rounded-full text-sm hover:bg-sky-50 transition-colors duration-200">Repair</a>
        <a href="#installation" class="bg-white text-sky-600 font-semibold px-4 py-2 rounded-full text-sm hover:bg-sky-50 transition-colors duration-200">Installation</a>
        <a href="#shifting" class="bg-white text-sky-600 font-semibold px-4 py-2 rounded-full text-sm hover:bg-sky-50 transition-colors duration-200">Shifting</a>
        <a href="#commercial" class="bg-white text-sky-600 font-semibold px-4 py-2 rounded-full text-sm hover:bg-sky-50 transition-colors duration-200">Commercial</a>
        <a href="#amc" class="bg-white text-sky-600 font-semibold px-4 py-2 rounded-full text-sm hover:bg-sky-50 transition-colors duration-200">AMC</a>
        <a href="#buy-sell" class="bg-white text-sky-600 font-semibold px-4 py-2 rounded-full text-sm hover:bg-sky-50 transition-colors duration-200">Buy & Sell</a>
      </div>
      <p class="text-white/80 text-sm">
        All brands serviced &middot; Jaipur, Rajasthan &middot; Call <a href="tel:9928731910" class="underline font-semibold text-white hover:text-sky-100">9928731910</a>
      </p>
    </div>
  </section>

  <!-- AC Repair & Maintenance -->
  <section id="repair" class="scroll-mt-24 py-16 md:py-20 bg-crisp-white">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-4xl mx-auto">
        <div class="flex items-center gap-3 mb-6">
          <div class="w-12 h-12 rounded-xl bg-sky-100 flex items-center justify-center flex-shrink-0">
            <svg class="w-6 h-6 text-ice-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"></path>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
            </svg>
          </div>
          <h2 class="font-heading text-3xl md:text-4xl font-bold text-deep-navy">AC Repair & Maintenance</h2>
        </div>

        <p class="text-slate-gray text-lg leading-relaxed mb-4">
          Is your air conditioner not cooling properly, making unusual noises, or leaking water? Vishwakarma Aircon provides fast, reliable AC repair services across Jaipur for all major brands including Daikin, Voltas, LG, Samsung, Blue Star, Carrier, Hitachi, and more. With over 20 years of hands-on experience, our technicians diagnose and fix problems accurately the first time.
        </p>
        <p class="text-slate-gray text-lg leading-relaxed mb-4">
          We understand that a broken AC in Jaipur's extreme heat is an emergency. As the go-to experts for air conditioner repair in Jaipur, we offer same-day service for most repair calls. Whether it is a gas refill, compressor issue, PCB failure, or thermostat malfunction, we carry the necessary parts and tools to get your AC running again quickly.
        </p>
        <p class="text-slate-gray text-lg leading-relaxed mb-8">
          Regular maintenance prevents costly breakdowns and extends the lifespan of your unit. Our comprehensive servicing includes deep cleaning of filters, coils, and drain lines, performance testing, and a full system health check to keep your AC running at peak efficiency.
        </p>

        <div class="bg-sky-50 rounded-2xl p-6 md:p-8 mb-8">
          <h3 class="font-heading text-xl font-semibold text-deep-navy mb-4">What's Included</h3>
          <ul class="space-y-3">
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-cool-green flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
              <span class="text-slate-gray">Complete diagnosis and fault detection for all AC types (split, window, cassette, tower)</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-cool-green flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
              <span class="text-slate-gray">Gas refilling (R22, R32, R410A) with leak testing</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-cool-green flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
              <span class="text-slate-gray">Compressor repair and replacement</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-cool-green flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
              <span class="text-slate-gray">PCB board, capacitor, and thermostat repair</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-cool-green flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
              <span class="text-slate-gray">Deep cleaning of indoor and outdoor units, filters, and coils</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-cool-green flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
              <span class="text-slate-gray">Drain line cleaning and water leakage resolution</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-cool-green flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
              <span class="text-slate-gray">Performance optimization and energy efficiency check</span>
            </li>
          </ul>
        </div>

        <div class="bg-cyan-50 rounded-2xl p-6 md:p-8 mb-8">
          <h3 class="font-heading text-xl font-semibold text-deep-navy mb-3">Who Is This For?</h3>
          <p class="text-slate-gray leading-relaxed">
            Homeowners, tenants, landlords, and small businesses in Jaipur who need their existing AC units repaired or serviced. Whether your AC has stopped cooling, is making strange sounds, or simply needs its annual tune-up before summer, this service is for you.
          </p>
        </div>

        <div class="text-center">
          <a href="/contact" class="inline-flex items-center gap-2 bg-arctic-teal text-white font-heading font-semibold px-8 py-4 rounded-xl hover:bg-cyan-600 transition-colors duration-200 text-lg shadow-lg shadow-cyan-500/25">
            Book a Repair
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- New AC Installation -->
  <section id="installation" class="scroll-mt-24 py-16 md:py-20 bg-gray-50">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-4xl mx-auto">
        <div class="flex items-center gap-3 mb-6">
          <div class="w-12 h-12 rounded-xl bg-cyan-100 flex items-center justify-center flex-shrink-0">
            <svg class="w-6 h-6 text-arctic-teal" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"></path>
            </svg>
          </div>
          <h2 class="font-heading text-3xl md:text-4xl font-bold text-deep-navy">New AC Installation</h2>
        </div>

        <p class="text-slate-gray text-lg leading-relaxed mb-4">
          Getting a new air conditioner installed properly is just as important as choosing the right brand. Incorrect installation leads to poor cooling, higher electricity bills, frequent breakdowns, and a shorter AC lifespan. At Vishwakarma Aircon, we ensure every installation is done right — from selecting the correct tonnage for your room size to precise copper piping, proper wall mounting, and thorough testing.
        </p>
        <p class="text-slate-gray text-lg leading-relaxed mb-4">
          Our installation team has handled thousands of installations across Jaipur — in apartments, bungalows, offices, shops, and showrooms. We work with all major brands and all AC types including split ACs, window ACs, cassette ACs, and multi-split systems. We bring our own tools, brackets, piping, and materials so you do not have to worry about a thing.
        </p>
        <p class="text-slate-gray text-lg leading-relaxed mb-8">
          We also provide honest guidance on which AC capacity and type suits your space, usage pattern, and budget. Our goal is not just to install your AC but to ensure it delivers maximum comfort and efficiency for years to come.
        </p>

        <div class="bg-white rounded-2xl p-6 md:p-8 mb-8 shadow-sm">
          <h3 class="font-heading text-xl font-semibold text-deep-navy mb-4">What's Included</h3>
          <ul class="space-y-3">
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-cool-green flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
              <span class="text-slate-gray">Free site survey and tonnage recommendation based on room size</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-cool-green flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
              <span class="text-slate-gray">Professional wall mounting with heavy-duty brackets</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-cool-green flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
              <span class="text-slate-gray">Copper piping, drain pipe, and electrical wiring setup</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-cool-green flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
              <span class="text-slate-gray">Vacuum pump gas charging for optimal performance</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-cool-green flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
              <span class="text-slate-gray">Stabilizer and MCB installation (if needed)</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-cool-green flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
              <span class="text-slate-gray">Complete testing, demo, and post-installation cleanup</span>
            </li>
          </ul>
        </div>

        <div class="bg-white rounded-2xl p-6 md:p-8 mb-8 shadow-sm">
          <h3 class="font-heading text-xl font-semibold text-deep-navy mb-3">Who Is This For?</h3>
          <p class="text-slate-gray leading-relaxed">
            Anyone in Jaipur purchasing a new air conditioner — whether for a new home, a renovation project, or replacing an old unit. Also ideal for builders, interior designers, and property managers who need bulk AC installations with professional-grade quality.
          </p>
        </div>

        <div class="text-center">
          <a href="/contact" class="inline-flex items-center gap-2 bg-arctic-teal text-white font-heading font-semibold px-8 py-4 rounded-xl hover:bg-cyan-600 transition-colors duration-200 text-lg shadow-lg shadow-cyan-500/25">
            Schedule Installation
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- AC Shifting / Relocation -->
  <section id="shifting" class="scroll-mt-24 py-16 md:py-20 bg-crisp-white">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-4xl mx-auto">
        <div class="flex items-center gap-3 mb-6">
          <div class="w-12 h-12 rounded-xl bg-emerald-100 flex items-center justify-center flex-shrink-0">
            <svg class="w-6 h-6 text-cool-green" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4"></path>
            </svg>
          </div>
          <h2 class="font-heading text-3xl md:text-4xl font-bold text-deep-navy">AC Shifting / Relocation</h2>
        </div>

        <p class="text-slate-gray text-lg leading-relaxed mb-4">
          Moving to a new home or office? Your air conditioner needs careful handling during relocation. Improper dismantling, transport, or reinstallation can damage the compressor, cause gas leaks, and void your warranty. Vishwakarma Aircon provides professional AC shifting services in Jaipur that ensure your unit is safely relocated without any damage.
        </p>
        <p class="text-slate-gray text-lg leading-relaxed mb-4">
          Our trained technicians follow a systematic process: safe gas recovery, careful dismounting of indoor and outdoor units, secure packaging for transport, and precise reinstallation at your new location. We also inspect the unit for any existing issues and perform a full service before reinstalling.
        </p>
        <p class="text-slate-gray text-lg leading-relaxed mb-8">
          Whether you are shifting within the same building, across Jaipur, or to a nearby city, we handle everything end to end. We bring fresh copper piping, brackets, and all necessary materials for the new installation so your AC works just as well in its new home.
        </p>

        <div class="bg-emerald-50 rounded-2xl p-6 md:p-8 mb-8">
          <h3 class="font-heading text-xl font-semibold text-deep-navy mb-4">What's Included</h3>
          <ul class="space-y-3">
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-cool-green flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
              <span class="text-slate-gray">Safe gas recovery and unit dismantling at current location</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-cool-green flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
              <span class="text-slate-gray">Secure packaging and safe transportation</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-cool-green flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
              <span class="text-slate-gray">Fresh copper piping and new brackets at new location</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-cool-green flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
              <span class="text-slate-gray">Complete reinstallation with vacuum pump gas charging</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-cool-green flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
              <span class="text-slate-gray">Pre-installation inspection and cleaning of both units</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-cool-green flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
              <span class="text-slate-gray">Post-installation testing and performance verification</span>
            </li>
          </ul>
        </div>

        <div class="bg-emerald-50 rounded-2xl p-6 md:p-8 mb-8">
          <h3 class="font-heading text-xl font-semibold text-deep-navy mb-3">Who Is This For?</h3>
          <p class="text-slate-gray leading-relaxed">
            Homeowners and renters relocating within Jaipur or to nearby areas, businesses shifting to new office spaces, and landlords who need to move AC units between properties. Also useful if you want to move an AC from one room to another within the same building.
          </p>
        </div>

        <div class="text-center">
          <a href="/contact" class="inline-flex items-center gap-2 bg-arctic-teal text-white font-heading font-semibold px-8 py-4 rounded-xl hover:bg-cyan-600 transition-colors duration-200 text-lg shadow-lg shadow-cyan-500/25">
            Get Shifting Quote
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Commercial AC Solutions -->
  <section id="commercial" class="scroll-mt-24 py-16 md:py-20 bg-gray-50">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-4xl mx-auto">
        <div class="flex items-center gap-3 mb-6">
          <div class="w-12 h-12 rounded-xl bg-indigo-100 flex items-center justify-center flex-shrink-0">
            <svg class="w-6 h-6 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path>
            </svg>
          </div>
          <h2 class="font-heading text-3xl md:text-4xl font-bold text-deep-navy">Commercial AC Solutions</h2>
        </div>

        <p class="text-slate-gray text-lg leading-relaxed mb-4">
          Commercial spaces have unique cooling requirements that demand specialized expertise. Whether you run a showroom, restaurant, hotel, hospital, factory, or large office, Vishwakarma Aircon provides end-to-end commercial air conditioning solutions tailored to your space and usage patterns. We work with ductable units, VRF/VRV systems, package units, cassette ACs, and centralized cooling systems.
        </p>
        <p class="text-slate-gray text-lg leading-relaxed mb-4">
          Our commercial team begins with a detailed site assessment to understand your cooling load, space layout, electrical infrastructure, and budget. We then design a cooling solution that balances performance, energy efficiency, and cost-effectiveness. From procurement to installation to commissioning, we manage the entire project.
        </p>
        <p class="text-slate-gray text-lg leading-relaxed mb-8">
          We also provide ongoing maintenance contracts for commercial clients to ensure your cooling systems run reliably year-round. Downtime in a commercial setting means lost business — our priority is to keep that from happening with proactive maintenance and rapid response times.
        </p>

        <div class="bg-white rounded-2xl p-6 md:p-8 mb-8 shadow-sm">
          <h3 class="font-heading text-xl font-semibold text-deep-navy mb-4">What's Included</h3>
