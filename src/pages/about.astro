---
import BaseLayout from '../layouts/BaseLayout.astro';

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "AboutPage",
  "mainEntity": {
    "@type": "LocalBusiness",
    "name": "Vishwakarma Aircon",
    "description": "Jaipur's trusted AC service provider with 20+ years of experience in AC repair, installation, shifting, and commercial cooling solutions.",
    "foundingDate": "2004",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Jaipur",
      "addressRegion": "Rajasthan",
      "addressCountry": "IN"
    },
    "telephone": "+919928731910",
    "email": "vishwakarmaairconinfo@gmail.com",
    "url": "https://vishwakarmaaircon.com"
  }
};

const teamMembers = [
  {
    name: 'Vishwakarma Ji',
    role: 'Owner & Founder',
    description: 'With over 20 years of hands-on experience, he founded Vishwakarma Aircon with a vision to deliver honest, reliable AC services across Jaipur.',
  },
  {
    name: 'Ramesh Kumar',
    role: 'Lead Technician',
    description: 'A certified HVAC specialist with 12+ years of expertise in diagnosing and repairing all major AC brands and models.',
  },
  {
    name: 'Sunil Verma',
    role: 'Operations Manager',
    description: 'Ensures seamless scheduling, timely service delivery, and customer satisfaction for every project we undertake.',
  },
];

const brands = [
  'Daikin', 'LG', 'Samsung', 'Voltas', 'Blue Star',
  'Carrier', 'Hitachi', 'Haier', 'Whirlpool', 'Panasonic', 'O General',
];
---

<BaseLayout
  title="About Vishwakarma Aircon — 20+ Years of AC Excellence in Jaipur"
  description="Learn about Vishwakarma Aircon, Jaipur's trusted AC service provider with 20+ years experience. Expert team, all brands serviced, residential to commercial."
  jsonLd={jsonLd}
>
  <!-- Hero Section -->
  <section class="relative bg-gradient-to-r from-sky-500 to-cyan-400 pt-28 pb-16 overflow-hidden">
    <div class="absolute inset-0 opacity-10">
      <div class="absolute top-10 left-10 w-72 h-72 bg-white rounded-full blur-3xl"></div>
      <div class="absolute bottom-10 right-10 w-96 h-96 bg-white rounded-full blur-3xl"></div>
    </div>
    <div class="container mx-auto px-4 relative z-10 text-center">
      <h1 class="font-heading text-4xl md:text-5xl lg:text-6xl font-bold text-crisp-white mb-4">
        About Vishwakarma Aircon
      </h1>
      <p class="text-lg md:text-xl text-white/90 max-w-2xl mx-auto">
        Jaipur's most trusted name in AC services for over two decades
      </p>
    </div>
  </section>

  <!-- Company Story Section -->
  <section class="py-16 md:py-24 bg-crisp-white">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto">
        <div class="flex items-center gap-3 mb-8">
          <div class="w-12 h-1 bg-arctic-teal rounded-full"></div>
          <h2 class="font-heading text-3xl md:text-4xl font-bold text-deep-navy">Our Story</h2>
        </div>

        <div class="space-y-6 text-slate-gray text-lg leading-relaxed">
          <p>
            Vishwakarma Aircon began over 20 years ago as a small AC repair shop in the heart of Jaipur.
            Founded by a passionate technician with a deep understanding of cooling systems, the business
            was built on a simple promise: provide honest, reliable, and affordable AC services to every
            household and business in the city. What started as one-man operations quickly earned a
            reputation for quality workmanship and transparent pricing.
          </p>
          <p>
            Over the years, we grew from handling basic window AC repairs to mastering the latest split AC
            technology, VRV/VRF systems, and large-scale commercial HVAC installations. Our team expanded
            with skilled, certified technicians who share the same commitment to excellence. We invested in
            modern diagnostic tools, stayed current with emerging AC technologies, and built partnerships
            with all major brands to ensure our customers always receive genuine parts and expert care.
          </p>
          <p>
            Today, Vishwakarma Aircon is proud to be one of Jaipur's leading AC service providers, serving
            thousands of satisfied residential and commercial clients across the city. From individual
            homeowners in Malviya Nagar to builders developing large housing societies, from school
            campuses to corporate offices, we deliver end-to-end cooling solutions tailored to every need
            and budget. Our journey of 20+ years is a testament to the trust our customers place in us
            every single day.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Mission Statement Section -->
  <section class="py-16 md:py-20 bg-ice-blue/10">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto">
        <div class="bg-crisp-white rounded-2xl shadow-lg border-l-4 border-arctic-teal p-8 md:p-12">
          <div class="flex items-center gap-3 mb-6">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 text-arctic-teal flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="10"></circle>
              <path d="M12 16v-4"></path>
              <path d="M12 8h.01"></path>
            </svg>
            <h2 class="font-heading text-3xl md:text-4xl font-bold text-deep-navy">Our Mission</h2>
          </div>
          <p class="text-slate-gray text-lg md:text-xl leading-relaxed">
            To be Jaipur's most dependable AC service provider by delivering exceptional quality,
            transparent pricing, and prompt service. We are committed to keeping every home, office,
            and commercial space comfortably cool through expert craftsmanship, genuine parts, and a
            customer-first approach. Our goal is to build lasting relationships based on trust,
            integrity, and consistent results — ensuring that when you think of AC service, you think
            of Vishwakarma Aircon.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Team Section -->
  <section class="py-16 md:py-24 bg-crisp-white">
    <div class="container mx-auto px-4">
      <div class="text-center mb-14">
        <div class="flex items-center justify-center gap-3 mb-4">
          <div class="w-12 h-1 bg-arctic-teal rounded-full"></div>
          <h2 class="font-heading text-3xl md:text-4xl font-bold text-deep-navy">Meet Our Team</h2>
          <div class="w-12 h-1 bg-arctic-teal rounded-full"></div>
        </div>
        <p class="text-slate-gray text-lg max-w-2xl mx-auto">
          The skilled professionals behind Jaipur's most trusted AC service
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-5xl mx-auto">
        {teamMembers.map((member) => (
          <div class="bg-crisp-white rounded-2xl shadow-md hover:shadow-xl transition-shadow duration-300 overflow-hidden group">
            <!-- Photo Placeholder -->
            <div class="h-56 bg-gradient-to-br from-sky-400 via-cyan-400 to-arctic-teal flex items-center justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-20 h-20 text-white/60 group-hover:scale-110 transition-transform duration-300" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
                <circle cx="12" cy="7" r="4"></circle>
              </svg>
            </div>
            <!-- Info -->
            <div class="p-6 text-center">
              <h3 class="font-heading text-xl font-bold text-deep-navy mb-1">{member.name}</h3>
              <p class="text-arctic-teal font-semibold text-sm uppercase tracking-wide mb-3">{member.role}</p>
              <p class="text-slate-gray text-sm leading-relaxed">{member.description}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Brands We Service Section -->
  <section class="py-16 md:py-24 bg-deep-navy">
    <div class="container mx-auto px-4">
      <div class="text-center mb-12">
        <div class="flex items-center justify-center gap-3 mb-4">
          <div class="w-12 h-1 bg-arctic-teal rounded-full"></div>
          <h2 class="font-heading text-3xl md:text-4xl font-bold text-crisp-white">Brands We Service</h2>
          <div class="w-12 h-1 bg-arctic-teal rounded-full"></div>
        </div>
        <p class="text-white/70 text-lg max-w-2xl mx-auto">
          Expert repair, installation, and maintenance for all leading AC brands
        </p>
      </div>

      <div class="flex flex-wrap justify-center gap-4 max-w-4xl mx-auto">
        {brands.map((brand) => (
          <span class="inline-flex items-center px-6 py-3 bg-white/10 backdrop-blur-sm border border-white/20 rounded-full text-crisp-white font-heading font-semibold text-base hover:bg-arctic-teal/30 hover:border-arctic-teal/50 transition-colors duration-300 cursor-default">
            {brand}
          </span>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-16 md:py-24 bg-gradient-to-br from-ice-blue/20 via-crisp-white to-arctic-teal/10">
    <div class="container mx-auto px-4">
      <div class="max-w-3xl mx-auto text-center">
        <h2 class="font-heading text-3xl md:text-4xl font-bold text-deep-navy mb-4">
          Ready to Experience the Best AC Service in Jaipur?
        </h2>
        <p class="text-slate-gray text-lg mb-8 max-w-2xl mx-auto">
          Whether you need a quick repair, a new installation, or a complete commercial cooling solution,
          our team is ready to help. Get in touch with us today.
        </p>
        <a
          href="/contact"
          class="inline-flex items-center gap-2 bg-arctic-teal text-crisp-white font-heading font-bold text-lg px-8 py-4 rounded-xl shadow-lg hover:bg-cool-green hover:shadow-xl transition-all duration-300 transform hover:-translate-y-0.5"
        >
          Contact Us Today
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="5" y1="12" x2="19" y2="12"></line>
            <polyline points="12 5 19 12 12 19"></polyline>
          </svg>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
