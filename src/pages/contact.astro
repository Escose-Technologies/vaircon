---
import BaseLayout from '../layouts/BaseLayout.astro';

const seoTitle = "Contact Us — Free AC Service Quote | Vishwakarma Aircon";
const seoDescription = "Contact Vishwakarma Aircon for AC repair, installation & more in Jaipur. Call 9928731910, WhatsApp us, or fill the form for a free quote.";
---

<BaseLayout title={seoTitle} description={seoDescription}>

  <!-- ===== HERO ===== -->
  <section class="bg-gradient-to-r from-sky-500 to-cyan-400 pt-28 pb-14 text-center">
    <div class="max-w-4xl mx-auto px-4">
      <h1 class="font-heading text-4xl md:text-5xl font-bold text-crisp-white drop-shadow-md">
        Contact Vishwakarma Aircon — Jaipur
      </h1>
      <p class="mt-4 text-lg md:text-xl text-white/90 font-body max-w-2xl mx-auto">
        Reach out for a free AC service quote — we're just a call or message away.
      </p>
    </div>
  </section>

  <!-- ===== CONTACT FORM & INFO ===== -->
  <section class="py-16 bg-crisp-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 grid grid-cols-1 lg:grid-cols-2 gap-12">

      <!-- LEFT — Contact Form -->
      <div class="bg-white rounded-2xl shadow-lg p-8 md:p-10 border border-gray-100">
        <h2 class="font-heading text-2xl md:text-3xl font-bold text-deep-navy mb-2">
          Get a Free Quote
        </h2>
        <p class="text-slate-gray font-body mb-8">
          Fill the form below and we'll get back to you within a few hours.
        </p>

        <form action="https://api.web3forms.com/submit" method="POST" class="space-y-6">

          <!-- Web3Forms access key — Get yours at https://web3forms.com -->
          <input type="hidden" name="access_key" value="ebeb1c75-80b2-40be-bfb5-d5b5413e9fb3" />

          <input type="hidden" name="subject" value="New AC Service Inquiry from Website" />

          <!-- Full Name -->
          <div>
            <label for="name" class="block text-sm font-semibold text-deep-navy font-body mb-1">
              Full Name <span class="text-red-500">*</span>
            </label>
            <input
              type="text"
              id="name"
              name="name"
              required
              placeholder="Your full name"
              class="w-full rounded-lg border border-gray-300 px-4 py-3 text-deep-navy font-body placeholder:text-gray-400 focus:outline-none focus:ring-2 focus:ring-ice-blue focus:border-ice-blue transition"
            />
          </div>

          <!-- Phone Number -->
          <div>
            <label for="phone" class="block text-sm font-semibold text-deep-navy font-body mb-1">
              Phone Number <span class="text-red-500">*</span>
            </label>
            <input
              type="tel"
              id="phone"
              name="phone"
              required
              placeholder="e.g. 9928731910"
              class="w-full rounded-lg border border-gray-300 px-4 py-3 text-deep-navy font-body placeholder:text-gray-400 focus:outline-none focus:ring-2 focus:ring-ice-blue focus:border-ice-blue transition"
            />
          </div>

          <!-- City / Area -->
          <div>
            <label for="city" class="block text-sm font-semibold text-deep-navy font-body mb-1">
              City / Area
            </label>
            <input
              type="text"
              id="city"
              name="city"
              placeholder="e.g. Malviya Nagar, Jaipur"
              class="w-full rounded-lg border border-gray-300 px-4 py-3 text-deep-navy font-body placeholder:text-gray-400 focus:outline-none focus:ring-2 focus:ring-ice-blue focus:border-ice-blue transition"
            />
          </div>

          <!-- Service Required -->
          <div>
            <label for="service" class="block text-sm font-semibold text-deep-navy font-body mb-1">
              Service Required
            </label>
            <select
              id="service"
              name="service"
              class="w-full rounded-lg border border-gray-300 px-4 py-3 text-deep-navy font-body bg-white focus:outline-none focus:ring-2 focus:ring-ice-blue focus:border-ice-blue transition"
            >
              <option value="" disabled selected>Select a service</option>
              <option value="AC Repair">AC Repair</option>
              <option value="New AC Installation">New AC Installation</option>
              <option value="AC Shifting">AC Shifting</option>
              <option value="Commercial AC">Commercial AC</option>
              <option value="AMC">AMC</option>
              <option value="Buy Old AC">Buy Old AC</option>
              <option value="Sell Old AC">Sell Old AC</option>
            </select>
          </div>

          <!-- Message -->
          <div>
            <label for="message" class="block text-sm font-semibold text-deep-navy font-body mb-1">
              Message
            </label>
            <textarea
              id="message"
              name="message"
              rows="4"
              placeholder="Tell us more about your AC issue or requirement..."
              class="w-full rounded-lg border border-gray-300 px-4 py-3 text-deep-navy font-body placeholder:text-gray-400 focus:outline-none focus:ring-2 focus:ring-ice-blue focus:border-ice-blue transition resize-y"
            ></textarea>
          </div>

          <!-- Submit Button -->
          <button
            type="submit"
            class="w-full bg-arctic-teal hover:bg-arctic-teal/90 text-crisp-white font-heading font-bold text-lg py-3 px-6 rounded-lg shadow-md hover:shadow-lg transition-all duration-300 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-arctic-teal"
          >
            Send Inquiry
          </button>
        </form>
      </div>

      <!-- RIGHT — Contact Info -->
      <div class="flex flex-col gap-8">
        <div>
          <h2 class="font-heading text-2xl md:text-3xl font-bold text-deep-navy mb-2">
            Get in Touch
          </h2>
          <p class="text-slate-gray font-body">
            Prefer a quick call or message? Reach us directly using any of the options below.
          </p>
        </div>

        <div class="space-y-6">

          <!-- Phone -->
          <a
            href="tel:+919928731910"
            class="flex items-start gap-4 bg-white rounded-xl shadow-md p-5 border border-gray-100 hover:shadow-lg hover:border-ice-blue transition group"
          >
            <div class="flex-shrink-0 w-12 h-12 rounded-full bg-ice-blue/10 flex items-center justify-center group-hover:bg-ice-blue/20 transition">
              <svg class="w-6 h-6 text-arctic-teal" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
            </div>
            <div>
              <h3 class="font-heading font-bold text-deep-navy text-lg">Phone</h3>
              <p class="text-arctic-teal font-body font-semibold">9928731910</p>
              <p class="text-sm text-slate-gray font-body">Tap to call us directly</p>
            </div>
          </a>

          <!-- WhatsApp -->
          <a
            href="https://wa.me/919928731910"
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-start gap-4 bg-white rounded-xl shadow-md p-5 border border-gray-100 hover:shadow-lg hover:border-cool-green transition group"
          >
            <div class="flex-shrink-0 w-12 h-12 rounded-full bg-cool-green/10 flex items-center justify-center group-hover:bg-cool-green/20 transition">
              <svg class="w-6 h-6 text-cool-green" fill="currentColor" viewBox="0 0 24 24">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z" />
              </svg>
            </div>
            <div>
              <h3 class="font-heading font-bold text-deep-navy text-lg">WhatsApp</h3>
              <p class="text-cool-green font-body font-semibold">9928731910</p>
              <p class="text-sm text-slate-gray font-body">Chat with us on WhatsApp</p>
            </div>
          </a>

          <!-- Email -->
          <a
            href="mailto:vishwakarmaairconinfo@gmail.com"
            class="flex items-start gap-4 bg-white rounded-xl shadow-md p-5 border border-gray-100 hover:shadow-lg hover:border-ice-blue transition group"
          >
            <div class="flex-shrink-0 w-12 h-12 rounded-full bg-ice-blue/10 flex items-center justify-center group-hover:bg-ice-blue/20 transition">
              <svg class="w-6 h-6 text-arctic-teal" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
            </div>
            <div>
              <h3 class="font-heading font-bold text-deep-navy text-lg">Email</h3>
              <p class="text-arctic-teal font-body font-semibold break-all">vishwakarmaairconinfo@gmail.com</p>
              <p class="text-sm text-slate-gray font-body">Send us an email anytime</p>
            </div>
          </a>

          <!-- Working Hours -->
          <div class="flex items-start gap-4 bg-white rounded-xl shadow-md p-5 border border-gray-100">
            <div class="flex-shrink-0 w-12 h-12 rounded-full bg-ice-blue/10 flex items-center justify-center">
              <svg class="w-6 h-6 text-arctic-teal" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <div>
              <h3 class="font-heading font-bold text-deep-navy text-lg">Working Hours</h3>
              <p class="text-slate-gray font-body">
                <span class="font-semibold text-deep-navy">Mon – Sat:</span> 8:00 AM – 8:00 PM
              </p>
              <p class="text-slate-gray font-body">
                <span class="font-semibold text-deep-navy">Sun:</span> Emergency Only
              </p>
            </div>
          </div>

        </div>
      </div>

    </div>
  </section>

  <!-- ===== GOOGLE MAPS ===== -->
  <section class="py-16 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="font-heading text-2xl md:text-3xl font-bold text-deep-navy text-center mb-8">
        Find Us on the Map
      </h2>
      <div class="w-full rounded-2xl overflow-hidden shadow-lg relative">
        <iframe src="https://www.google.com/maps/embed?pb=!1m13!1m8!1m3!1d914.4086865925901!2d75.81586326885572!3d26.92000487412568!3m2!1i1024!2i768!4f13.1!3m2!1m1!2zMjbCsDU1JzExLjgiTiA3NcKwNDgnNTcuOSJF!5e0!3m2!1sen!2sin!4v1773144302339!5m2!1sen!2sin" class="w-full h-80 md:h-96" style="border:0;" allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade" title="Vishwakarma Aircon location on Google Maps"></iframe>
      </div>
      <div class="text-center mt-6">
        <a
          href="https://www.google.com/maps/dir/?api=1&destination=26.919944,75.815997"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 bg-arctic-teal text-white px-6 py-3 rounded-xl font-heading font-semibold hover:bg-ice-blue transition-colors shadow-md"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="3 11 22 2 13 21 11 13 3 11"></polygon></svg>
          Get Directions
        </a>
      </div>
    </div>
  </section>

</BaseLayout>
