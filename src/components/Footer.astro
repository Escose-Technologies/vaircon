          <li>
            <a href="mailto:vishwakarmaairconinfo@gmail.com" class="flex items-center gap-3 text-gray-400 hover:text-arctic-teal transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-arctic-teal flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"></rect><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path></svg>
