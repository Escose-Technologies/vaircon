          <li class="flex items-center gap-3 text-gray-400">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-arctic-teal flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
