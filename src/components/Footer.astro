          </li>
        </ul>
      </div>
    </div>

    <!-- Bottom Bar -->
    <div class="border-t border-gray-800 mt-10 pt-6 flex flex-col md:flex-row items-center justify-between gap-4 text-gray-500 text-sm">
      <p>Vishwakarma Aircon</p>
      <p>&copy; {new Date().getFullYear()} Vishwakarma Aircon. All rights reserved.</p>
