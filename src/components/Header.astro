---
const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/services', label: 'Services' },
  { href: '/about', label: 'About' },
  { href: '/gallery', label: 'Gallery' },
  { href: '/contact', label: 'Contact' },
];
---

<header id="site-header" class="fixed top-0 left-0 right-0 z-50 transition-all duration-300 bg-transparent">
  <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-14 md:h-16">
      <!-- Logo -->
      <a href="/" id="logo" class="flex items-center gap-2">
        <img id="logo-img" src="/images/logo.png" alt="Vishwakarma Aircon" class="h-10 md:h-12 w-auto brightness-0 invert transition-all duration-300" width="160" height="48" />
        <span id="logo-text" class="font-heading font-bold text-lg md:text-xl text-white transition-all duration-300">VISHWAKARMA <span id="logo-accent" class="text-white/80">AIRCON</span></span>
      </a>

      <!-- Desktop Navigation -->
      <div class="hidden md:flex items-center gap-8">
        {navLinks.map((link) => (
          <a
            href={link.href}
            class="nav-link text-white hover:text-white/80 font-medium transition-colors text-sm uppercase tracking-wide"
          >
            {link.label}
          </a>
        ))}
        <a
          href="tel:9928731910"
          class="bg-arctic-teal text-white px-5 py-2.5 rounded-lg font-semibold hover:bg-ice-blue transition-colors text-sm flex items-center gap-2"
        >
          <!-- Phone icon -->
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
          Call Now
        </a>
      </div>

      <!-- Mobile Menu Button -->
      <button
        id="mobile-menu-btn"
        class="md:hidden p-2 text-white hover:text-white/80"
        aria-label="Toggle menu"
        aria-expanded="false"
      >
        <svg id="menu-icon" xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="3" y1="6" x2="21" y2="6"></line>
          <line x1="3" y1="12" x2="21" y2="12"></line>
          <line x1="3" y1="18" x2="21" y2="18"></line>
        </svg>
        <svg id="close-icon" xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 hidden" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="18" y1="6" x2="6" y2="18"></line>
          <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
      </button>
    </div>

    <!-- Mobile Menu -->
    <div id="mobile-menu" class="md:hidden hidden pb-4">
      <div class="flex flex-col gap-3 bg-white rounded-lg p-4 shadow-lg">
        {navLinks.map((link) => (
          <a
            href={link.href}
            class="text-slate-gray hover:text-ice-blue font-medium py-2 border-b border-gray-100 last:border-0"
          >
            {link.label}
          </a>
        ))}
        <a
          href="tel:9928731910"
          class="bg-arctic-teal text-white px-5 py-3 rounded-lg font-semibold text-center mt-2"
        >
          Call Now: 9928731910
        </a>
      </div>
    </div>
  </nav>
</header>

<script>
  // Sticky header with background and color swap on scroll
  const header = document.getElementById('site-header');
  const logoImg = document.getElementById('logo-img');
  const logoText = document.getElementById('logo-text');
  const logoAccent = document.getElementById('logo-accent');
  const navLinks = document.querySelectorAll('.nav-link');
  const menuBtn = document.getElementById('mobile-menu-btn');

  function updateHeader() {
    if (window.scrollY > 50) {
      header?.classList.add('bg-white', 'shadow-md');
      header?.classList.remove('bg-transparent');
      logoImg?.classList.remove('brightness-0', 'invert');
      logoText?.classList.remove('text-white');
      logoText?.classList.add('text-ice-blue');
      logoAccent?.classList.remove('text-white/80');
      logoAccent?.classList.add('text-arctic-teal');
      navLinks.forEach(link => {
        link.classList.remove('text-white', 'hover:text-white/80');
        link.classList.add('text-slate-gray', 'hover:text-ice-blue');
      });
      menuBtn?.classList.remove('text-white', 'hover:text-white/80');
      menuBtn?.classList.add('text-slate-gray', 'hover:text-ice-blue');
    } else {
      header?.classList.remove('bg-white', 'shadow-md');
      header?.classList.add('bg-transparent');
      logoImg?.classList.add('brightness-0', 'invert');
      logoText?.classList.add('text-white');
      logoText?.classList.remove('text-ice-blue');
      logoAccent?.classList.add('text-white/80');
      logoAccent?.classList.remove('text-arctic-teal');
      navLinks.forEach(link => {
        link.classList.add('text-white', 'hover:text-white/80');
        link.classList.remove('text-slate-gray', 'hover:text-ice-blue');
      });
      menuBtn?.classList.add('text-white', 'hover:text-white/80');
      menuBtn?.classList.remove('text-slate-gray', 'hover:text-ice-blue');
    }
  }

  window.addEventListener('scroll', updateHeader);
  updateHeader(); // run once on load

  // Mobile menu toggle
  const mobileMenu = document.getElementById('mobile-menu');
  const menuIcon = document.getElementById('menu-icon');
  const closeIcon = document.getElementById('close-icon');

  menuBtn?.addEventListener('click', () => {
    const isOpen = !mobileMenu?.classList.contains('hidden');
    mobileMenu?.classList.toggle('hidden');
    menuIcon?.classList.toggle('hidden');
    closeIcon?.classList.toggle('hidden');
    menuBtn?.setAttribute('aria-expanded', String(!isOpen));
  });
</script>
