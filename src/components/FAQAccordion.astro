---
export interface Props {
  question: string;
  answer: string;
  id: string;
}

const { question, answer, id } = Astro.props;
---

<div class="border border-gray-200 rounded-lg overflow-hidden">
  <label for={id} class="flex items-center justify-between p-4 cursor-pointer hover:bg-gray-50 transition-colors">
    <span class="font-semibold text-deep-navy pr-4">{question}</span>
    <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-ice-blue flex-shrink-0 transition-transform" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"></polyline></svg>
  </label>
  <input type="checkbox" id={id} class="faq-toggle hidden peer" />
  <div class="faq-content max-h-0 overflow-hidden transition-all duration-300 px-4 peer-checked:max-h-96 peer-checked:py-3">
    <p class="text-slate-gray leading-relaxed">{answer}</p>
  </div>
</div>
